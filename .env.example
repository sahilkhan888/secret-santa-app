# Supabase — get these from `supabase start` output (local) or the Supabase dashboard (hosted).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email. Leave blank during session 1 to enable stub mode
# (rendered HTML is logged and written to tmp/last-email.html instead of sent).
RESEND_API_KEY=
RESEND_FROM_EMAIL=santa@example.com

# Anthropic — used by the gift-suggestions route (session 2+).
ANTHROPIC_API_KEY=

# Comma-separated admin emails. Leave blank for v1 and fill in before going live.
# Example: alice@company.com,bob@company.com
ADMIN_EMAILS=

# Used to build absolute URLs in outgoing emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
